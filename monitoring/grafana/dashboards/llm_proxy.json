{
  "title": "LLM Proxy (LiteLLM)",
  "uid": "llm-proxy-dash",
  "schemaVersion": 38,
  "version": 5,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["llm", "proxy", "litellm"],
  "panels": [
    {
      "id": 100,
      "title": "Requests",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "title": "Requests Since Restart",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(litellm_request_total_latency_metric_count) or on() vector(0)",
          "legendFormat": "requests",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 8,
      "title": "Failures Since Restart",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "expr": "sum(litellm_deployment_failure_responses_total) or on() vector(0)",
          "legendFormat": "failures",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 10,
      "title": "Traffic by Model",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "sum(litellm_request_total_latency_metric_count) by (requested_model)",
          "legendFormat": "{{requested_model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "pie",
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "right" }
      }
    },
    {
      "id": 1,
      "title": "Requests by Model (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(litellm_request_total_latency_metric_count[30s])) by (requested_model)",
          "legendFormat": "{{requested_model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 5,
      "title": "Success vs Failure by Provider (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 7 },
      "targets": [
        {
          "expr": "sum(rate(litellm_deployment_success_responses_total[30s])) by (litellm_model_name)",
          "legendFormat": "ok {{litellm_model_name}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(litellm_deployment_failure_responses_total[30s])) by (litellm_model_name)",
          "legendFormat": "err {{litellm_model_name}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 9,
      "title": "Error Rate by Provider (%)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 7 },
      "targets": [
        {
          "expr": "100 * sum(rate(litellm_deployment_failure_responses_total[30s])) by (litellm_model_name) / clamp_min(sum(rate(litellm_deployment_success_responses_total[30s])) by (litellm_model_name) + sum(rate(litellm_deployment_failure_responses_total[30s])) by (litellm_model_name), 0.0001)",
          "legendFormat": "{{litellm_model_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 101,
      "title": "Latency",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "End-to-End Latency (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(litellm_request_total_latency_metric_sum[30s])) by (requested_model) / clamp_min(sum(rate(litellm_request_total_latency_metric_count[30s])) by (requested_model), 0.001)",
          "legendFormat": "{{requested_model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "title": "Queue Time (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(litellm_request_queue_time_seconds_sum[30s])) by (requested_model) / clamp_min(sum(rate(litellm_request_queue_time_seconds_count[30s])) by (requested_model), 0.001)",
          "legendFormat": "{{requested_model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "title": "Upstream API Latency (s)",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "sum(rate(litellm_llm_api_latency_metric_sum[30s])) by (requested_model) / clamp_min(sum(rate(litellm_llm_api_latency_metric_count[30s])) by (requested_model), 0.001)",
          "legendFormat": "{{requested_model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2.0 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 14,
      "title": "Proxy Overhead (s)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "sum(rate(litellm_overhead_latency_metric_sum[30s])) by (litellm_model_name) / clamp_min(sum(rate(litellm_overhead_latency_metric_count[30s])) by (litellm_model_name), 0.001)",
          "legendFormat": "{{litellm_model_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 102,
      "title": "Cost",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 12,
      "title": "Spend Since Restart",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 29 },
      "targets": [
        {
          "expr": "sum(litellm_spend_metric_total) or on() vector(0)",
          "legendFormat": "spend",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 13,
      "title": "Avg Cost / Request ($)",
      "type": "bargauge",
      "gridPos": { "h": 3, "w": 8, "x": 4, "y": 29 },
      "targets": [
        {
          "expr": "sum(litellm_spend_metric_total) by (model) / clamp_min(sum(litellm_request_total_latency_metric_count) by (model), 1)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6,
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 4,
      "title": "Tokens In vs Out",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "targets": [
        {
          "expr": "sum(rate(litellm_output_tokens_metric_total[30s])) by (model)",
          "legendFormat": "out {{model}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(litellm_input_tokens_metric_total[30s])) by (model)",
          "legendFormat": "in {{model}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 11,
      "title": "Spend by Model ($)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum(rate(litellm_spend_metric_total[30s])) by (model)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 105,
      "title": "Agent",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 20,
      "title": "Requests/s by Trigger",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 41 },
      "targets": [
        {
          "expr": "sum(rate(chronos_agent_requests_total[1m])) by (trigger)",
          "legendFormat": "{{trigger}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 21,
      "title": "Agent Request Duration (s)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 41 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(chronos_agent_request_duration_seconds_bucket[1m])) by (le, trigger))",
          "legendFormat": "p50 {{trigger}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(chronos_agent_request_duration_seconds_bucket[1m])) by (le, trigger))",
          "legendFormat": "p95 {{trigger}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "min": 0 }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 22,
      "title": "Tool Errors/s by Type",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 41 },
      "targets": [
        {
          "expr": "sum(rate(chronos_agent_tool_errors_total[1m])) by (error_type)",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 23,
      "title": "Actions/s by Type & Status",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 47 },
      "targets": [
        {
          "expr": "sum(rate(chronos_agent_actions_total[1m])) by (action_type, status)",
          "legendFormat": "{{action_type}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 104,
      "title": "Streaming",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 53 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 18,
      "title": "TTFT — Time to First Token (s)",
      "description": "Время до первого токена (P50/P95/P99). При non-streaming запросах = полное время ответа LLM API. При stream=true — реальное время до первого чанка.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 54 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(litellm_llm_api_time_to_first_token_metric_bucket[1m])) by (le, model))",
          "legendFormat": "p50 {{model}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(litellm_llm_api_time_to_first_token_metric_bucket[1m])) by (le, model))",
          "legendFormat": "p95 {{model}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(litellm_llm_api_time_to_first_token_metric_bucket[1m])) by (le, model))",
          "legendFormat": "p99 {{model}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "min": 0
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 19,
      "title": "TPOT — Time per Output Token (ms/token)",
      "description": "Среднее время на генерацию одного токена = LLM API latency / output_tokens. Показывает скорость генерации провайдера.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 54 },
      "targets": [
        {
          "expr": "1000 * sum(rate(litellm_llm_api_latency_metric_sum[1m])) by (requested_model) / clamp_min(sum(rate(litellm_output_tokens_metric_total[1m])) by (requested_model), 0.001)",
          "legendFormat": "{{requested_model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "min": 0
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 103,
      "title": "Infra",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 62 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 15,
      "title": "CPU Usage by cgroup (% of 1 core)",
      "description": "Docker Desktop на macOS не предоставляет per-container cgroups — показываем агрегат по cgroup-группам. На Linux-хосте метрика будет разбита по контейнерам.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 63 },
      "targets": [
        {
          "expr": "100 * rate(container_cpu_usage_seconds_total[1m])",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "min": 0
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 16,
      "title": "Host Memory Breakdown",
      "description": "Разбивка памяти хоста (node-exporter). Docker-total — суммарная RSS всех контейнеров.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 63 },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "container_memory_usage_bytes{id=\"/docker\"}",
          "legendFormat": "docker total",
          "refId": "B"
        },
        {
          "expr": "node_memory_Buffers_bytes + node_memory_Cached_bytes",
          "legendFormat": "buffers+cache",
          "refId": "C"
        },
        {
          "expr": "node_memory_MemFree_bytes",
          "legendFormat": "free",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "min": 0
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 17,
      "title": "Host CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 71 },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[30s])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ]
}
