# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Публичный HTTPS URL вашего сервера + /webhook/telegram
# Dev: ngrok → https://xxxx.ngrok.io/webhook/telegram
# Prod: https://yourdomain.com/webhook/telegram
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET_CHECK=false

# --- Google OAuth 2.0 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Публичный HTTPS-адрес для OAuth callback (в dev — ngrok URL)
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback
GOOGLE_WEBHOOK_BASE_URL=https://your-domain.com
# HMAC-ключ для подписи state-параметра (защита от CSRF)
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
OAUTH_STATE_SECRET=

# --- Шифрование OAuth-токенов пользователей ---
# Генерация: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- LLM основной: Mistral ---
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1
LLM_MAX_TOKENS=512


# --- PostgreSQL ---
POSTGRES_URL=postgresql+asyncpg://chronos:chronos@postgres:5432/chronos

# --- Langfuse v2 (self-hosted) ---
LANGFUSE_PUBLIC_KEY=pk-lf
LANGFUSE_SECRET_KEY=sk-lf
LANGFUSE_HOST=http://langfuse:3000

LANGFUSE_INIT_USER_EMAIL=admin@admin.com
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=admin12345678

# --- Whisper ASR ---
# Модель: base / small / medium
WHISPER_MODEL=base
# Устройство: cpu / cuda
WHISPER_DEVICE=cpu
# Тип вычислений: int8 (CPU) / float16 (GPU)
WHISPER_COMPUTE_TYPE=int8

# --- Агент ---
CONFIDENCE_THRESHOLD=0.6
CONFIRMATION_TIMEOUT_SECONDS=300
AGENT_ITERATION_TIMEOUT_SECONDS=30
MAX_TOOL_CALLS_PER_ITERATION=3
SEARCH_WINDOW_HOURS=24
CRON_INTERVAL_MINUTES=60
WEBHOOK_RENEWAL_INTERVAL_DAYS=6
ORPHAN_SESSION_TIMEOUT_MINUTES=10

# --- Rate limiting ---
RATE_LIMIT_MSG_PER_MINUTE=5

# --- Логирование ---
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# --- Ограничения ввода ---
MAX_TEXT_LENGTH=4000
MAX_AUDIO_SIZE_MB=20
AUDIO_RETENTION_DAYS=14


# --- LLM Proxy ---
# LLM_PROXY_ENABLED — куда отправляет запросы сам агент:
#   false → напрямую в Mistral (MISTRAL_API_KEY + MISTRAL_BASE_URL)
#   true  → через LiteLLM proxy (LLM_PROXY_URL)
LLM_PROXY_ENABLED=true
LLM_PROXY_URL=http://llm-proxy:8001/v1
LLM_PROXY_API_KEY=dev-key-1
LITELLM_DATABASE_URL=postgresql://litellm:litellm@postgres:5432/litellm


